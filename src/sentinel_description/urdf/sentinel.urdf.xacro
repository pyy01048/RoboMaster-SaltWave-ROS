<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sentinel_robot">
  <xacro:arg name="base_length" default="0.55"/>
  <xacro:arg name="base_width" default="0.45"/>
  <xacro:arg name="base_height" default="0.22"/>
  <xacro:arg name="lidar_x" default="0.2"/>
  <xacro:arg name="lidar_y" default="0.0"/>
  <xacro:arg name="lidar_z" default="0.3"/>
  <xacro:arg name="lidar_roll" default="0.0"/>
  <xacro:arg name="lidar_pitch" default="0.785"/>
  <xacro:arg name="lidar_yaw" default="0.0"/>
  <xacro:arg name="camera_x" default="0.16"/>
  <xacro:arg name="camera_y" default="0.0"/>
  <xacro:arg name="camera_z" default="0.42"/>

  <material name="dark_gray">
    <color rgba="0.12 0.13 0.14 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.05 0.22 0.8 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.11" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="$(arg base_length) $(arg base_width) $(arg base_height)"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="$(arg base_length) $(arg base_width) $(arg base_height)"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="18.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.45" ixy="0.0" ixz="0.0" iyy="0.55" iyz="0.0" izz="0.72"/>
    </inertial>
  </link>

  <joint name="gimbal_yaw_joint" type="continuous">
    <parent link="base_link"/>
    <child link="gimbal_yaw_link"/>
    <origin xyz="0.02 0 0.18" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="gimbal_yaw_link">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="gimbal_pitch_joint" type="revolute">
    <parent link="gimbal_yaw_link"/>
    <child link="gimbal_pitch_link"/>
    <origin xyz="0.08 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.35" upper="0.70" effort="8.0" velocity="8.0"/>
  </joint>

  <link name="gimbal_pitch_link">
    <visual>
      <origin xyz="0.09 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.22"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="$(arg lidar_x) $(arg lidar_y) $(arg lidar_z)" rpy="$(arg lidar_roll) $(arg lidar_pitch) $(arg lidar_yaw)"/>
  </joint>

  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.045" length="0.045"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="livox_base_link_joint" type="fixed">
    <parent link="laser_frame"/>
    <child link="livox_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="livox_base_link"/>

  <joint name="livox_frame_joint" type="fixed">
    <parent link="livox_base_link"/>
    <child link="livox_frame"/>
    <origin xyz="0 0 0.13" rpy="0 0 0"/>
  </joint>

  <link name="livox_frame">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.125"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://livox_ros_driver2/MID360_config/MID360.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://livox_ros_driver2/MID360_config/MID360.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.02"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="gimbal_pitch_link"/>
    <child link="camera_link"/>
    <origin xyz="$(arg camera_x) $(arg camera_y) $(arg camera_z)" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
      <material name="dark_gray"/>
    </visual>
  </link>
</robot>
